# =============================================================
# ASU Global Connect — .gitignore
# =============================================================

# ---------------------------------------------------------------
# SECRETS — Never commit these
# ---------------------------------------------------------------
# Contains JWT keys, DB passwords, secret keys
config.yml

# ---------------------------------------------------------------
# GENERATED FILES — Recreated by `tutor config save`
# ---------------------------------------------------------------
env/

# ---------------------------------------------------------------
# DATA VOLUMES — Database files (hundreds of MB)
# ---------------------------------------------------------------
data/

# ---------------------------------------------------------------
# LOGS
# ---------------------------------------------------------------
*.log
tutor-launch.log

# ---------------------------------------------------------------
# LOCAL CLAUDE CODE SETTINGS
# ---------------------------------------------------------------
.claude/

# ---------------------------------------------------------------
# Python
# ---------------------------------------------------------------
__pycache__/
*.py[cod]
*.pyo
*.pyd
*.egg
*.egg-info/
dist/
build/
.eggs/
.tox/
.venv/
venv/
env/
*.so

# ---------------------------------------------------------------
# Test / Coverage artifacts
# ---------------------------------------------------------------
.coverage
coverage.xml
htmlcov/
.pytest_cache/
.mypy_cache/

# ---------------------------------------------------------------
# Node / JS (inside xblocks)
# ---------------------------------------------------------------
node_modules/
npm-debug.log*
yarn-error.log

# ---------------------------------------------------------------
# macOS
# ---------------------------------------------------------------
.DS_Store
.AppleDouble
.LSOverride
Thumbs.db

# ---------------------------------------------------------------
# IDEs
# ---------------------------------------------------------------
.idea/
.vscode/
*.swp
*.swo
